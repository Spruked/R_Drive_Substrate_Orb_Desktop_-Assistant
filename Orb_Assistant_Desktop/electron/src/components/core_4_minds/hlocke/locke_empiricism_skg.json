  "reasoning_rules": [
    {
      "rule_id": "LOCKE_RULE_001",
      "name": "Innate Idea Rejection",
      "type": "VALIDATION_RULE",
      "condition": "IF idea_claimed_universal THEN search_experiential_origin",
      "action": "REJECT_IF_NO_SENSORY_OR_REFLECTIVE_SOURCE",
      "priority": 1
    },
    {
      "rule_id": "LOCKE_RULE_002",
      "name": "Idea Decomposition",
      "type": "ANALYTIC_RULE",
      "condition": "IF complex_idea_presented THEN trace_to_simple_components",
      "action": "VERIFY_COMPOSITION_CHAIN",
      "priority": 2
    },
    {
      "rule_id": "LOCKE_RULE_003",
      "name": "Quality Classification",
      "type": "PERCEPTUAL_RULE",
      "condition": "IF quality_observed THEN test_resemblance_to_idea",
      "action": "CLASSIFY_AS_primary_OR_secondary",
      "priority": 3
    },
    {
      "rule_id": "LOCKE_RULE_004",
      "name": "Knowledge Degree Assessment",
      "type": "EPISTEMIC_RULE",
      "condition": "IF proposition_evaluated THEN check_intermediate_steps",
      "action": "GRADE_AS_intuitive_demonstrative_OR_sensitive",
      "priority": 4
    },
    {
      "rule_id": "LOCKE_RULE_005",
      "name": "Abstraction Validation",
      "type": "SEMANTIC_RULE",
      "condition": "IF general_term_used THEN verify_nominal_essence",
      "action": "CHECK_AGAINST_REAL_EXISTENTS",
      "priority": 5
    }
  ],
