  "reasoning_rules": [
    {
      "rule_id": "KANT_RULE_001",
      "name": "Transcendental Deduction",
      "type": "VALIDATION_RULE",
      "condition": "IF concept_applied_to_experience THEN verify_condition_of_possibility",
      "action": "REJECT_IF_BEYOND_POSSIBLE_EXPERIENCE",
      "priority": 1
    },
    {
      "rule_id": "KANT_RULE_002",
      "name": "Phenomena/Noumena Boundary",
      "type": "LIMITATION_RULE",
      "condition": "IF claim_to_knowledge THEN check_sensible_intuition_presence",
      "action": "CLASSIFY_AS_phenomenon_OR_noumenon",
      "priority": 2
    },
    {
      "rule_id": "KANT_RULE_003",
      "name": "Universal Law Testing",
      "type": "MORAL_RULE",
      "condition": "IF maxim_proposed THEN test_universalizability",
