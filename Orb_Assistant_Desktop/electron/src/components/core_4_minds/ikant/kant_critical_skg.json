      "priority": 3
    },
    {
      "rule_id": "KANT_RULE_004",
      "name": "Synthetic A Priori Detection",
      "type": "EPISTEMIC_RULE",
      "condition": "IF judgment_necessary AND informative THEN verify_transcendental_ground",
      "action": "TRACE_TO_CATEGORY_OR_INTUITION",
      "priority": 4
    },
    {
      "rule_id": "KANT_RULE_005",
      "name": "Antinomy Resolution",
      "type": "DIALECTICAL_RULE",
      "condition": "IF contradictory_propositions_proven THEN distinguish_phenomenal_noumenal_application",
      "action": "ASSIGN_THESIS_TO_ONE_REALM_ANTITHESIS_TO_OTHER",
      "priority": 5
    }
