{
  "category": "Advanced API Imports",
  "version": "1.0",
  "updated": "2026-03-21",
  "apis": [
    {
      "name": "NIH RePORTER",
      "category": "Biomedical Research",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "projects_search": "https://api.reporter.nih.gov/v2/projects/search",
        "publications_search": "https://api.reporter.nih.gov/v2/publications/search",
        "clinical_trials_search": "https://api.reporter.nih.gov/v2/clinical_trials/search"
      }
    },
    {
      "name": "ClinicalTrials.gov",
      "category": "Biomedical Research",
      "auth": "none",
      "rate_limit": "low",
      "endpoints": {
        "study_fields": "https://clinicaltrials.gov/api/query/study_fields",
        "full_studies": "https://clinicaltrials.gov/api/query/full_studies",
        "field_values": "https://clinicaltrials.gov/api/query/field_values"
      }
    },
    {
      "name": "NCBI Entrez",
      "category": "Biomedical Research",
      "auth": "api_key_optional",
      "rate_limit": "strict",
      "endpoints": {
        "esearch": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
        "efetch": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi",
        "esummary": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi"
      }
    },
    {
      "name": "PubChem",
      "category": "Chemistry",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "by_name": "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/name/{name}/JSON",
        "by_cid": "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/cid/{cid}/JSON",
        "by_smiles": "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/smiles/{smiles}/JSON"
      }
    },
    {
      "name": "Ensembl",
      "category": "Genomics",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "lookup": "https://rest.ensembl.org/lookup/id/{id}",
        "sequence": "https://rest.ensembl.org/sequence/id/{id}",
        "overlap": "https://rest.ensembl.org/overlap/id/{id}"
      }
    },
    {
      "name": "UniProt",
      "category": "Proteomics",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "search": "https://rest.uniprot.org/uniprotkb/search?query={query}",
        "entry": "https://rest.uniprot.org/uniprotkb/{accession}"
      }
    },
    {
      "name": "Protein Data Bank (PDB)",
      "category": "Structural Biology",
      "auth": "none",
      "rate_limit": "low",
      "endpoints": {
        "entry": "https://data.rcsb.org/rest/v1/core/entry/{pdb_id}",
        "assembly": "https://data.rcsb.org/rest/v1/core/assembly/{pdb_id}"
      }
    },
    {
      "name": "NASA Earthdata CMR",
      "category": "Earth Systems",
      "auth": "none",
      "rate_limit": "moderate",
