        "granules": "https://cmr.earthdata.nasa.gov/search/granules.json",
        "collections": "https://cmr.earthdata.nasa.gov/search/collections.json"
      }
    },
    {
      "name": "NOAA Climate Data Online",
      "category": "Climate",
      "auth": "api_key_required",
      "rate_limit": "strict",
      "endpoints": {
        "data": "https://www.ncei.noaa.gov/cdo-web/api/v2/data",
        "datasets": "https://www.ncei.noaa.gov/cdo-web/api/v2/datasets",
        "stations": "https://www.ncei.noaa.gov/cdo-web/api/v2/stations"
