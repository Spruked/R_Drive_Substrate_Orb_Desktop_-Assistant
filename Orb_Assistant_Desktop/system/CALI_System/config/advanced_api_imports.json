      "auth": "none",
      "rate_limit": "low",
      "endpoints": {
        "query": "https://earthquake.usgs.gov/fdsnws/event/1/query?format=geojson"
      }
    },
    {
      "name": "USGS National Map",
      "category": "Geospatial",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "products": "https://tnmaccess.nationalmap.gov/api/v1/products",
        "datasets": "https://tnmaccess.nationalmap.gov/api/v1/datasets"
      }
    },
    {
      "name": "OpenStreetMap Overpass",
      "category": "Geospatial",
      "auth": "none",
      "rate_limit": "strict",
      "endpoints": {
