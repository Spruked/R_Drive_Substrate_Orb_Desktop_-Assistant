      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "entries": "https://nomad-lab.eu/prod/v1/api/entries",
        "materials": "https://nomad-lab.eu/prod/v1/api/materials"
      }
    },
    {
