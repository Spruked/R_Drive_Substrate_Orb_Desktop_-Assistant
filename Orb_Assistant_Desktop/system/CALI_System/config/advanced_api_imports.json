      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "latest": "https://api.openaq.org/v2/latest",
        "measurements": "https://api.openaq.org/v2/measurements"
      }
    },
    {
      "name": "Materials Project",
      "category": "Materials Science",
      "auth": "api_key_required",
      "rate_limit": "moderate",
      "endpoints": {
        "materials": "https://api.materialsproject.org/materials/{mpid}",
        "summary": "https://api.materialsproject.org/summary/{mpid}"
      }
    },
    {
