      "category": "Knowledge Graph",
      "auth": "none",
      "rate_limit": "low",
      "endpoints": {
        "entities": "https://www.wikidata.org/w/api.php?action=wbgetentities&ids={id}&format=json",
        "sparql": "https://query.wikidata.org/sparql?query={sparql}"
      }
    },
    {
