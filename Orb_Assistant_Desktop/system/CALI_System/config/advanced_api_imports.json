      "category": "Academic Research",
      "auth": "none",
      "rate_limit": "moderate",
      "endpoints": {
        "paper_search": "https://api.semanticscholar.org/graph/v1/paper/search?query={query}",
        "author": "https://api.semanticscholar.org/graph/v1/author/{id}",
        "paper": "https://api.semanticscholar.org/graph/v1/paper/{paperId}"
      }
    },
    {
      "name": "OpenAlex",
      "category": "Academic Research",
      "auth": "none",
      "rate_limit": "low",
      "endpoints": {
        "works": "https://api.openalex.org/works?filter={filters}",
        "authors": "https://api.openalex.org/authors/{id}",
        "institutions": "https://api.openalex.org/institutions/{id}"
